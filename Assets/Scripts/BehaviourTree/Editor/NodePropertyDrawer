using UnityEditor;
using UnityEngine;
using System.Linq;

[CustomPropertyDrawer(typeof(NodeProperty<>))]
public class NodePropertyDrawer : PropertyDrawer
{
    public override void OnGUI(Rect position, SerializedProperty property, GUIContent label)
    {
        var modeProp = property.FindPropertyRelative("propertyMode");
        var constantProp = property.FindPropertyRelative("constantValue");
        var variableNameProp = property.FindPropertyRelative("variableName");

        float lineHeight = EditorGUIUtility.singleLineHeight;
        Rect labelRect = new Rect(position.x, position.y, position.width * 0.3f, lineHeight);
        Rect modeRect = new Rect(position.x + position.width * 0.3f, position.y, 70, lineHeight);
        Rect valueRect = new Rect(position.x + position.width * 0.3f + 75, position.y,
            position.width - position.width * 0.3f - 75, lineHeight);

        EditorGUI.LabelField(labelRect, label);

        // Draw mode popup
        int modeIndex = modeProp.enumValueIndex;
        modeIndex = EditorGUI.Popup(modeRect, modeIndex, System.Enum.GetNames(typeof(NodeProperty<int>.Mode)));
        modeProp.enumValueIndex = modeIndex;

        if ((NodeProperty<int>.Mode)modeIndex == NodeProperty<int>.Mode.Constant)
        {
            EditorGUI.PropertyField(valueRect, constantProp, GUIContent.none);
        }
        else
        {
            var def = BehaviourTreeEditor.CurrentBlackboardDefinition;
            if (def != null)
            {
                // Get the generic type T of this property
                System.Type targetType = fieldInfo.FieldType.GetGenericArguments()[0];
                string typeFullName = targetType.FullName;

                var matchingVars = def.variables
                    .Where(v => v.typeName == typeFullName)
                    .Select(v => v.name)
                    .ToArray();

                int currentIndex = System.Array.IndexOf(matchingVars, variableNameProp.stringValue);
                if (currentIndex < 0) currentIndex = 0;
                currentIndex = EditorGUI.Popup(valueRect, currentIndex, matchingVars);
                variableNameProp.stringValue = (currentIndex >= 0 && matchingVars.Length > 0)
                    ? matchingVars[currentIndex] : "";
            }
            else
            {
                EditorGUI.LabelField(valueRect, "(No blackboard)");
            }
        }
    }

    public override float GetPropertyHeight(SerializedProperty property, GUIContent label)
        => EditorGUIUtility.singleLineHeight;
}